# =================================================================
# PPCI SaaS - Variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA faça commit do .env com a chave verdadeira
# =================================================================

# Chave da API Anthropic (obtenha em https://console.anthropic.com)
# Formato: sk-ant-api03-XXXXXXXXXXXX...
ANTHROPIC_API_KEY=sk-ant-api03-SUACHAVEAQUI

# Modelo padrão (opcional, padrão: claude-sonnet-4-6)
# Outras opções: claude-opus-4-7 (mais caro, mais preciso), claude-haiku-4-5 (mais barato)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS - domínios permitidos (separados por vírgula)
# Em desenvolvimento, pode deixar *. Em produção, especifique seu domínio.
CORS_ORIGINS=*

# Porta do servidor (Railway/Render definem automaticamente)
PORT=8000
